# SQLite 数据库地址；相对路径以程序启动目录为基准。
DATABASE_URL=sqlite://./data/rain.db
# 上传文件、解压结果和临时处理目录的根路径。
RAIN_DATA_ROOT=./data/uploads
# 后端运行日志的保存目录。
RAIN_LOG_DIR=./log
# 后端监听地址；0.0.0.0 表示监听所有网络接口。
SERVER_HOST=0.0.0.0
# 后端监听端口。
SERVER_PORT=8080
# 是否在启动时重建数据库并清空上传目录；仅建议本地开发时使用。
RESET_DB=false
# 上传数据的自动保留天数；设置为 0 或留空表示不自动清理。
RAIN_RETENTION_DAYS=0

# 上传限制
# 单次请求最多允许上传的文件数量，必须大于 0。
RAIN_UPLOAD_MAX_FILES=100
# 单个上传文件的最大大小；支持 B、KiB、MiB、GiB、TiB，且不能大于上传总大小。
RAIN_UPLOAD_MAX_FILE_SIZE=512 MiB
# 单次请求所有上传文件的累计最大大小；支持二进制大小单位。
RAIN_UPLOAD_MAX_TOTAL_SIZE=2 GiB
# multipart 普通文本字段的最大大小；支持二进制大小单位。
RAIN_UPLOAD_MAX_TEXT_FIELD_SIZE=64 KiB
# 同时进行解压和索引的后台任务数量，必须大于 0。
RAIN_UPLOAD_CONCURRENT_PROCESSING_TASKS=2

# 压缩包解压限制
# 一个 bundle 内所有压缩包累计允许解压的最大大小；支持二进制大小单位。
RAIN_ARCHIVE_MAX_EXTRACTED_SIZE=500 MiB
# 单个压缩条目允许解压的最大大小；不能大于 bundle 累计解压大小。
RAIN_ARCHIVE_MAX_ENTRY_SIZE=100 MiB
# 一个 bundle 内累计允许处理的压缩条目数量，目录也计入，必须大于 0。
RAIN_ARCHIVE_MAX_ENTRIES=10000
# 压缩条目内部路径允许包含的最大目录层数。
RAIN_ARCHIVE_MAX_PATH_DEPTH=16
# 嵌套压缩包允许递归解压的最大层数。
RAIN_ARCHIVE_MAX_RECURSION_DEPTH=16
# 解压输出完整路径允许的最大 UTF-16 字符数，用于兼容 Windows 路径限制。
RAIN_ARCHIVE_MAX_OUTPUT_PATH_CHARS=1024
# 未压缩大小与压缩大小之间允许的最大比例，用于防止压缩炸弹。
RAIN_ARCHIVE_MAX_COMPRESSION_RATIO=100

# 日志索引限制
# 单行日志允许读取和索引的最大字节数；超出部分会截断并标记。
RAIN_INDEXING_MAX_LINE_SIZE=1 MiB
# 每个 SQLite FTS 全文索引 chunk 包含的最大日志行数。
RAIN_INDEXING_CHUNK_LINES=200
# 每个 bundle 最多保存的结构化日志事件数量，用于限制 SQLite 体积。
# 超过后仍会保留完整日志分段和全文搜索，只停止写入额外的结构化事件记录。
RAIN_INDEXING_MAX_EVENTS_PER_BUNDLE=250000
# 索引多少行后提交一次数据库事务；较小更稳健，较大通常更快。
RAIN_INDEXING_COMMIT_LINES=5000
# 每隔多少行记录一次字节偏移，用于分页时快速跳转。
RAIN_INDEXING_LINE_OFFSET_INTERVAL=1000

# API 响应限制
# 文件内容预览最多读取的字节数；支持二进制大小单位。
RAIN_API_FILE_PREVIEW_SIZE=64 KiB
# 未指定 limit 时，文件和临时结果行接口默认返回的行数。
RAIN_API_DEFAULT_LINE_PAGE_SIZE=1000
# 文件和临时结果行接口单次允许返回的最大行数；默认值不能超过此值。
RAIN_API_MAX_LINE_PAGE_SIZE=3000
# 未指定 size 时，日志搜索接口默认返回的结果数量。
RAIN_API_DEFAULT_SEARCH_RESULTS=50
# 日志搜索接口单次允许返回的最大结果数量；默认值不能超过此值。
RAIN_API_MAX_SEARCH_RESULTS=100
