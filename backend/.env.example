DATABASE_URL=postgres://postgres:postgres@localhost:5432/rain
DATABASE_SCHEMA=Rain
RAIN_DATA_ROOT=../data/uploads
RAIN_LOG_DIR=../log
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RESET_DB=false
DOMAIN=rain.example.com
EXTERNAL_PORT=447
CERT_PATH=/etc/letsencrypt/live/rain/fullchain.pem
KEY_PATH=/etc/letsencrypt/live/rain/privkey.pem
STATIC_DEST=/var/www/rain
