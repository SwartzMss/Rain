DATABASE_URL=sqlite://./data/rain.db
RAIN_DATA_ROOT=./data/uploads
RAIN_LOG_DIR=./log
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RESET_DB=false
# 0 or empty disables automatic cleanup.
RAIN_RETENTION_DAYS=0

# Upload limits
RAIN_UPLOAD_MAX_FILES=100
RAIN_UPLOAD_MAX_FILE_SIZE=512 MiB
RAIN_UPLOAD_MAX_TOTAL_SIZE=2 GiB
RAIN_UPLOAD_MAX_TEXT_FIELD_SIZE=64 KiB
RAIN_UPLOAD_CONCURRENT_PROCESSING_TASKS=2

# Archive extraction limits
RAIN_ARCHIVE_MAX_EXTRACTED_SIZE=500 MiB
RAIN_ARCHIVE_MAX_ENTRY_SIZE=100 MiB
RAIN_ARCHIVE_MAX_ENTRIES=10000
RAIN_ARCHIVE_MAX_PATH_DEPTH=16
RAIN_ARCHIVE_MAX_RECURSION_DEPTH=16
RAIN_ARCHIVE_MAX_OUTPUT_PATH_CHARS=1024
RAIN_ARCHIVE_MAX_COMPRESSION_RATIO=100

# Log indexing limits
RAIN_INDEXING_MAX_LINE_SIZE=1 MiB
RAIN_INDEXING_CHUNK_LINES=200
RAIN_INDEXING_COMMIT_LINES=5000
RAIN_INDEXING_LINE_OFFSET_INTERVAL=1000

# API response limits
RAIN_API_FILE_PREVIEW_SIZE=64 KiB
RAIN_API_DEFAULT_LINE_PAGE_SIZE=1000
RAIN_API_MAX_LINE_PAGE_SIZE=3000
RAIN_API_DEFAULT_SEARCH_RESULTS=50
RAIN_API_MAX_SEARCH_RESULTS=100
